# Base de données Postgres (Neon.tech — copier le "Connection string" fourni après création du projet)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Port du serveur (Render fournit automatiquement PORT en prod, utile seulement en local)
PORT=4000

# URL du site frontend (pour CORS et pour construire les liens de retour de paiement)
FRONTEND_URL="https://app.kaleogroupe.com"

# URL publique de ce backend une fois déployé sur Render (pour le webhook CinetPay notify_url)
BACKEND_URL="https://kaleo-groupe-backend.onrender.com"

# CinetPay — récupérés dans le tableau de bord CinetPay (Intégration > API)
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
CINETPAY_SECRET=""
# Mettre à false uniquement quand le compte CinetPay est validé et en production
CINETPAY_TEST_MODE=true

# Admin
JWT_SECRET="change-moi-avec-une-longue-chaine-aleatoire"
ADMIN_EMAIL="kaleogroupe@gmail.com"
# Généré une seule fois via le script prisma/seed.js (voir README-backend.md)
ADMIN_PASSWORD="change-moi"

# Cloudinary (hébergement des images produits) — récupérés dans le dashboard Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Notifications email (confirmation client + alerte commande) — envoyées via Gmail SMTP.
# SMTP_USER : ton adresse Gmail. SMTP_PASS : un "mot de passe d'application" Gmail
# (PAS ton mot de passe normal) — voir backend/README-backend.md pour la procédure.
SMTP_USER="kaleogroupe@gmail.com"
SMTP_PASS=""
# Adresse qui reçoit les alertes de nouvelle commande (par défaut : SMTP_USER)
NOTIFY_EMAIL="kaleogroupe@gmail.com"
