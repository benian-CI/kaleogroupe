generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  paid
  failed
  cancelled
}

enum PaymentMethod {
  cinetpay
  cash
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  slug        String      @unique
  description String
  price       Int // en FCFA, entier (pas de centimes)
  category    String
  imageUrl    String?
  stock       Int         @default(0)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id                     Int           @id @default(autoincrement())
  ref                    String        @unique
  status                 OrderStatus   @default(pending)
  paymentMethod          PaymentMethod @default(cinetpay)
  customer               Customer?     @relation(fields: [customerId], references: [id])
  customerId             Int?
  customerName           String
  customerPhone          String
  customerEmail          String?
  deliveryAddress        String
  totalAmount            Int
  installationRequested  Boolean       @default(false)
  installationFee        Int           @default(0)
  cinetpayTransId        String?
  paidAt                 DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  items                  OrderItem[]
}

// Compte client optionnel (façon Jumia) : la commande fonctionne toujours sans
// compte (customerId reste null, "invité"), mais un client connecté retrouve
// l'historique de ses commandes.
model Customer {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  createdAt    DateTime @default(now())
  orders       Order[]
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order      Order   @relation(fields: [orderId], references: [id])
  orderId    Int
  product    Product @relation(fields: [productId], references: [id])
  productId  Int
  quantity   Int
  unitPrice  Int // prix au moment de la commande (snapshot, ne dépend pas d'un changement de prix ultérieur)
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
